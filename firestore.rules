rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'principal']) ||
        request.auth.token.email == "jamiasraijulaloom@gmail.com"
      );
    }

    function isStaff() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'principal', 'teacher', 'accountant', 'receptionist']) ||
        request.auth.token.email == "jamiasraijulaloom@gmail.com"
      );
    }

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /students/{studentId} {
      allow read, list: if isAuthenticated();
      allow write: if isStaff();
    }

    match /staff/{staffId} {
      allow read, list: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read, list: if isAuthenticated();
      allow write: if isStaff();
    }

    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /sections/{sectionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    match /examResults/{resultId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    match /feePayments/{paymentId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    match /salaryPayments/{paymentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
